# Copy this file to .env.e2e.local and fill in real credentials.
# The default Playwright projects target the deployed web apps directly.

# Shared smoke user
E2E_USER=
E2E_PASSWORD=

# Optional manager-only smoke user for the manager dashboard route
E2E_MANAGER_USER=
E2E_MANAGER_PASSWORD=

# Optional login mode when the post-login dialog is shown.
# Supported values: employee, line-manager
E2E_LOGIN_MODE=

# Optional base URL override, for example:
# E2E_BASE_URL=http://127.0.0.1:4173